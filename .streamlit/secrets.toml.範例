# 把這份的內容貼到 Streamlit Cloud 的 App → Settings → Secrets（不要把真的金鑰 commit 進 git）。
# 本機若也想讓網頁/ update.py 連雲端試算表，把真值另存成 .streamlit/secrets.toml（已被 gitignore）。

# Google 試算表的 ID：試算表網址 https://docs.google.com/spreadsheets/d/【這段就是 ID】/edit
progress_sheet_id = "在這裡貼試算表 ID"

# 服務帳號金鑰：把下載的 JSON 各欄位照樣填進來（private_key 連同 \n 整段照貼）
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...省略...\n-----END PRIVATE KEY-----\n"
client_email = "checklist-bot@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/checklist-bot%40your-project-id.iam.gserviceaccount.com"
