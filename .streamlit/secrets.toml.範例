# 把這份的內容貼到 Streamlit Cloud 的 App → Settings → Secrets（真值不要 commit 進 git）。
# 本機若也想連雲端，把真值另存成 .streamlit/secrets.toml（已被 gitignore）。

# ───────── 方案 B（推薦，不用服務帳號）─────────
# 部署 素材/checklist_webapp.gs 成 Apps Script 網頁應用程式後，把網址與 token 填這裡。
# token 要跟 .gs 裡的 TOKEN 一字不差。
checklist_webapp_url = "https://script.google.com/macros/s/XXXXXXXX/exec"
checklist_token = "貼一組你自己的隨機字串（與 .gs 的 TOKEN 一致）"


